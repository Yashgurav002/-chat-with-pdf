# Get your key at https://console.groq.com (GitHub login, no credit card)
GROQ_API_KEY=your_groq_api_key_here

# "production" uses HuggingFace embeddings + Groq LLM
# "local" swaps to Ollama for offline development
MODE=production

# Only used when MODE=local
OLLAMA_BASE_URL=http://localhost:11434

# Production: your Vercel frontend URL (for CORS)
# FRONTEND_URL=https://your-app.vercel.app
